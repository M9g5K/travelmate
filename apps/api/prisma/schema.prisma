// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String
  type             String
  nickname         String
  languages        String[]

  country          String?
  bio              String?
  profileImageUrl  String?

  refreshTokenHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  requests Request[]
  likes    Like[]

  travelerMatches Match[] @relation("TravelerMatches")
  localMatches    Match[] @relation("LocalMatches")

  messages Message[]
  chatMembers ChatMember[]

  reportsSent     Report[] @relation("ReportsSent")
  reportsReceived Report[] @relation("ReportsReceived")

  blocksSent     Block[] @relation("BlocksSent")
  blocksReceived Block[] @relation("BlocksReceived")

  reviewsWritten  Review[] @relation("ReviewsWritten")
  reviewsReceived Review[] @relation("ReviewsReceived")

  notifications Notification[]
}

enum RequestStatus {
  ACTIVE
  MATCHED
  CLOSED
}

enum LikeStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum MatchStatus {
  ACTIVE
  CLOSED
}

model Request {
  id          String        @id @default(uuid())
  travelerId  String
  traveler    User          @relation(fields: [travelerId], references: [id])

  city        String
  startDate   DateTime
  endDate     DateTime
  tags        String[]
  description String?

  modeInfoOnly Boolean @default(false)
  modeChat     Boolean @default(true)
  modeOffline  Boolean @default(false)

  status      RequestStatus @default(ACTIVE)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  likes       Like[]
  match       Match?
}

model Like {
  id        String     @id @default(uuid())
  requestId String
  request   Request    @relation(fields: [requestId], references: [id])

  localId   String
  local     User       @relation(fields: [localId], references: [id])

  status    LikeStatus @default(PENDING)

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([requestId, localId])
}

model Match {
  id         String      @id @default(uuid())
  requestId  String      @unique
  request    Request     @relation(fields: [requestId], references: [id])

  travelerId String
  traveler   User        @relation("TravelerMatches", fields: [travelerId], references: [id])

  localId    String
  local      User        @relation("LocalMatches", fields: [localId], references: [id])

  status     MatchStatus @default(ACTIVE)

  chat       Chat?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  reviews Review[]
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id])

  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])

  content   String

  createdAt DateTime @default(now())

  @@index([chatId, createdAt])
}

model Chat {
  id        String   @id @default(uuid())
  matchId   String   @unique
  match     Match    @relation(fields: [matchId], references: [id])

  messages  Message[]

  createdAt DateTime @default(now())

  members ChatMember[]
}

model ChatMember {
  id            String   @id @default(uuid())
  chatId        String
  chat          Chat     @relation(fields: [chatId], references: [id])

  userId        String
  user          User     @relation(fields: [userId], references: [id])

  lastReadAt    DateTime?
  lastReadMsgId String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([chatId, userId])
  @@index([chatId])
  @@index([userId])
}

model Report {
  id           String   @id @default(uuid())
  reporterId   String
  targetUserId String
  chatId       String?
  reason       String
  detail       String?
  createdAt    DateTime @default(now())

  reporter     User     @relation("ReportsSent", fields: [reporterId], references: [id])
  targetUser   User     @relation("ReportsReceived", fields: [targetUserId], references: [id])
}

model Block {
  id            String   @id @default(uuid())
  blockerId     String
  blockedUserId String
  createdAt     DateTime @default(now())

  blocker     User @relation("BlocksSent", fields: [blockerId], references: [id])
  blockedUser User @relation("BlocksReceived", fields: [blockedUserId], references: [id])

  @@unique([blockerId, blockedUserId])
}

model Review {
  id           String   @id @default(uuid())
  reviewerId   String
  targetUserId String
  matchId      String
  rating       Int
  comment      String?
  createdAt    DateTime @default(now())

  reviewer   User  @relation("ReviewsWritten", fields: [reviewerId], references: [id])
  targetUser User  @relation("ReviewsReceived", fields: [targetUserId], references: [id])
  match      Match @relation(fields: [matchId], references: [id])

  @@unique([reviewerId, matchId])
}

enum NotificationType {
  CHAT_MESSAGE
  REQUEST_LIKED
  MATCH_CREATED
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}